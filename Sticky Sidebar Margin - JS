document.addEventListener("DOMContentLoaded",()=>{const s=document.querySelector(".sticky-sidebar"),p=document.querySelector(".sidebar-column-height");if(!s||!p)return;let h=0,ticking=!1;const read=()=>{h=p.offsetHeight};const write=()=>{s.style.marginBottom=window.innerWidth>=782?`${h*3/5}px`:"0px"};const update=()=>{read();write()};update();window.addEventListener("resize",()=>{if(!ticking){requestAnimationFrame(()=>{update();ticking=!1});ticking=!0}})})
